# Copy this file to .env and fill in values.

# Required only for the summary add-on (the /ask --summary feature).
GEMINI_API_KEY=your-gemini-api-key-here

# Optional overrides (defaults shown).
GEMINI_MODEL=gemini-2.5-flash
# Prefix with "onnx:" to force the ONNX Runtime backend (used automatically
# when Windows Smart App Control blocks PyTorch's unsigned DLLs).
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
# Relative paths resolve against the project root, not the working directory.
YTA_DB_PATH=transcripts.db

# Seconds between videos during playlist import (higher = safer from rate limits).
#YTA_PLAYLIST_DELAY=3.0

# How often the running API server auto-syncs followed channels (0 = disable).
#YTA_SYNC_INTERVAL_MINUTES=360

# Days before a video skipped during sync (e.g. no captions yet) is retried.
#YTA_SKIP_RETRY_DAYS=7

# Route transcript requests through a proxy (escape hatch if YouTube keeps
# rate-limiting your network). Format: http://user:pass@host:port
#YTA_PROXY_URL=
